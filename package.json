{
  "name": "sitio-cafezinho",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "NODE_ENV=production vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "start:container": "node dist/db/migrate.js && node dist/db/seed.js && node dist/server/index.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:e2e": "node --env-file=.env ./node_modules/@playwright/test/cli.js test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "google-drive:authorize": "tsx scripts/google-drive-authorize.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "drizzle-orm": "^0.44.2",
    "googleapis": "^150.0.1",
    "hono": "^4.7.11",
    "lucide-react": "^1.24.0",
    "pg": "^8.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "recharts": "^3.9.2",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  }
}
