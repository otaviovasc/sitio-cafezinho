# Sem a chave, a captura por voz fica desativada (endpoints 503, UI oculta).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_STT_MODEL=google/chirp-3
OPENROUTER_INTENT_MODEL=google/gemini-3.1-flash-lite
