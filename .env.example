NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://sitio:sitio@db:5432/sitio
APP_PASSWORD=troque-esta-senha
SESSION_SECRET=troque-por-um-segredo-longo-com-32-caracteres
PUBLIC_APP_URL=http://localhost:3000
SEED_DEMO_DATA=true

STORAGE_MODE=local
LOCAL_STORAGE_PATH=/data/uploads

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
